{
	"$schema": "https://nitro.margelo.com/nitro.schema.json",
	"cxxNamespace": ["inappbrowsernitro"],
	"ios": {
		"iosModuleName": "InappbrowserNitro"
	},
	"android": {
		"androidNamespace": ["inappbrowsernitro"],
		"androidCxxLibName": "InappbrowserNitro"
	},
	"autolinking": {
		"InappbrowserNitro": {
			"ios": {
				"language": "swift",
				"implementationClassName": "HybridInappbrowserNitro"
			},
			"android": {
				"language": "kotlin",
				"implementationClassName": "HybridInappbrowserNitro"
			}
		}
	},
	"ignorePaths": ["**/node_modules"]
}
